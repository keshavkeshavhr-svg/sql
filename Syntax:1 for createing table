NOTE:WE CAN USE KEYWORDS ONLY FOR NUMERIC FORMAT DATATYPE

STUDENT:
--------
SID    INT         UNSIGNED NN PRIMARY KEY--->P_SID       
SNAME  VARCHAR(20)          NN 
PHONE  BIGINT      UNSIGNED NN UNIQUE,CHECK(LENGTH(PHONE)=10)
                               U_PH   C_PH

CREATE TABLE STUDENT
(
 SID INT UNSIGNED NOT NULL,
 SNAME VARCHAR(20) NOT NULL,
 PHONE BIGINT UNSIGNED NOT NULL,
 CONSTRAINT P_SID PRIMARY KEY(SID),
 CONSTRAINT U_PH UNIQUE(PHONE),
 CONSTRAINT C_PH CHECK(LENGTH(PHONE)=10)
);

BRANCH:
-------
BID      INT         UNSIGNED NN PRIMARY KEY---->P_BID
BNAME    VARCHAR(20)          NN 
ADDRESS  VARCHAR(30)          NN
PINCODE  INT         UNSIGNED NN UNIQUE CHECK(LENGTH(PINCODE)=6)
                                 U_PIN  C_PIN


CREATE TABLE BRANCH
(
 BID INT UNSIGNED NOT NULL,
 BNAME VARCHAR(20) NOT NULL,
 ADDRESS VARCHAR(30) NOT NULL,
 PINCODE INT UNSIGNED NOT NULL,
 CONSTRAINT P_BID PRIMARY KEY(BID),
 CONSTRAINT U_PIN UNIQUE(PINCODE),
 CONSTRAINT C_PIN CHECK(LENGTH(PINCODE)=6)
);

PRODUCT:
---------
PID      INT          NN   PRIMARY KEY---->P_PID
PNAME    VARCHAR(10)  NN
PRICE    DECIMAL(5,2) NN   CHECK(PRICE>0)--->C_PRICE
QUANTITY INT          NULL CHECK(QUANTITY>0)--->C_QUANTITY

CREATE TABLE PRODUCT
(
 PID INT NOT NULL,
 PNAME VARCHAR(10) NOT NULL,
 PRICE DECIMAL(5,2) NOT NULL,
 QUANTITY INT NULL,
 CONSTRAINT P_PID PRIMARY KEY(PID),
 CONSTRAINT C_PRICE CHECK(PRICE>0),
 CONSTRAINT C_QUANTITY CHECK(QUANTITY>0)
);

