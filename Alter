IT IS USED TO MODIFY TABLE STRUCTURE.

1.TO ADD NEW COLUMN_NAME
------------------------
SYNTAX:

ALTER TABLE TABLE_NAME
ADD NEW_COLUMN_NAME NEW_DATATYPE NULL/NOT NULL;

STUDENT--->EMAIL--->VARCHAR(20)--->NOT NULL

ALTER TABLE STUDENT
ADD EMAIL VARCHAR(20) NOT NULL;

2.TO ADD NEW_COLUMN_NAME AFTER PARTICULAR COLUMN.
---------------------------------------------------
SYNTAX:

ALTER TABLE TABLE_NAME
ADD NEW_COLUMN_NAME NEW_DATATYPE NULL/NOT NULL AFTER EXISTING_COLUMN_NAME;

STUDENT---BALANCE----INT----NULL---->SNAME

ALTER TABLE STUDENT
ADD BALANCE INT NULL AFTER SNAME;

3.TO ADD NEW COLUMN IN THE FIRST POSITION.
------------------------------------------
SYNTAX:

ALTER TABLE TABLE_NAME
ADD NEW_COLUMN_NAME NEW_DATATYPE NULL/NOT NULL FIRST;

STUDENT---AGE----INT----NULL

ALTER TABLE STUDENT
ADD AGE INT NULL FIRST;

4.TO DROP COLUMN_NAME
---------------------
SYNTAX:

ALTER TABLE TABLE_NAME
DROP EXISTING_COLUMN_NAME;

STUDENT---->EMAIL

ALTER TABLE STUDENT
DROP EMAIL;

5.TO CHANGE DATATYPE:
---------------------
SYNTAX:

ALTER TABLE TABLE_NAME
MODIFY EXISTING_COLUMN_NAME NEW_DATATYPE NULL/NOT NULL;

ALTER TABLE CUSTOMER
MODIFY ADDRESS CHAR(50) NOT NULL;

6.TO CHANGE NULL/NOT NULL
-------------------------
SYNTAX:

ALTER TABLE TABLE_NAME
MODIFY EXISTING_COLUMN_NAME EXISTING_DATATYPE NULL/NOT NULL;

ALTER TABLE CUSTOMER
MODIFY CNAME VARCHAR(30) NULL;

7.TO CHANGE TABLE_NAME
----------------------
SYNTAX:

ALTER TABLE TABLE_NAME
RENAME NEW_TABLE_NAME;

FACULTY----DEPT

ALTER TABLE FACULTY
RENAME DEPT;

8.TO CHANGE COLUMN_NAME
-----------------------
SYNTAX:

ALTER TABLE TABLE_NAME
RENAME COLUMN EXISTING_COLUMN_NAME TO NEW_COLUMN_NAME;

STUDENT----SNAME---STUDENT_NAME

ALTER TABLE STUDENT
RENAME COLUMN SNAME TO STUDENT_NAME;

ALTER TABLE STUDENT
RENAME COLUMN PHONE TO CONTACT;

ERROR:WE CANT RENAME A COLUMN IF COLUMN IS ASSIGNED WITH CHECK CONSTRAINT.
